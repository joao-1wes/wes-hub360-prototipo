{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Servidor estático (porta 5500)",
      "type": "shell",
      "command": "python -m http.server 5500 --bind 127.0.0.1",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "http-server",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP"
        }
      }
    },
    {
      "label": "Abrir dashboard no navegador (sem depurar)",
      "type": "shell",
      "command": "cmd /c start \"\" \"http://127.0.0.1:5500/index.html\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
